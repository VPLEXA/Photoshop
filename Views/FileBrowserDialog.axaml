<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:VectorEditor.Views"
        x:Class="VectorEditor.Views.FileBrowserDialog"
        WindowStartupLocation="CenterOwner"
        Width="560" Height="400"
        MinWidth="400" MinHeight="300"
        Background="White"
        ShowInTaskbar="False">

    <DockPanel Margin="10" LastChildFill="True">

        <!-- Top: path bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <Button x:Name="UpButton" DockPanel.Dock="Left" Content="↑" Width="32" Height="28"
                    FontSize="14" Margin="0,0,6,0" Click="OnUpClick" ToolTip.Tip="На уровень выше"/>
            <TextBox x:Name="PathBox" Height="28" FontSize="11" IsReadOnly="True"
                     Background="#F5F5F5" BorderBrush="#CCCCCC"/>
        </DockPanel>

        <!-- Bottom: filename + buttons -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0" Spacing="6">
            <DockPanel x:Name="FileNameRow">
                <TextBlock DockPanel.Dock="Left" Text="Имя файла:" VerticalAlignment="Center"
                           FontSize="11" Margin="0,0,8,0" Width="80"/>
                <TextBox x:Name="FileNameBox" Height="26" FontSize="11"
                         KeyDown="OnFileNameKeyDown"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Отмена" Width="90" Height="28" FontSize="12" Click="OnCancel"/>
                <Button x:Name="OkButton" Width="90" Height="28" FontSize="12"
                        Background="#0078D4" Foreground="White" Click="OnOk"/>
            </StackPanel>
        </StackPanel>

        <!-- Center: file list -->
        <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,0">
            <ListBox x:Name="FileList" Background="White" FontSize="11"
                     SelectionChanged="OnSelectionChanged"
                     DoubleTapped="OnDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:FileEntry">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

    </DockPanel>
</Window>
